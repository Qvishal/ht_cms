# Backend server
PORT=4000
NODE_ENV=development

# Postgres
# Example: postgres://user:pass@localhost:5432/db
DATABASE_URL=postgres://ht_cms:ht_cms@localhost:5432/ht_cms

# Redis (for caching)
# Example: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# Cache Configuration
CACHE_STRATEGY=HYBRID
CACHE_PUBLIC_ONLY=true

# Varnish Configuration
VARNISH_HOST=localhost:6081

# HTTPS / TLS Enforcement
# Set FORCE_HTTPS=true to enforce HTTPS on all API traffic
# Proxy mode (nginx/caddy terminates TLS): set FORCE_HTTPS=true only
# Native Bun TLS mode: set all three variables
FORCE_HTTPS=false
HTTPS_PORT=4433
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# Payload Encryption
# Set ENCRYPT_PAYLOADS=true to enable application-level encryption for JSON bodies
# Required: 64-character hex string (32 bytes)
ENCRYPT_PAYLOADS=false
# PAYLOAD_ENCRYPTION_KEY=your-64-char-hex-key
